# Copy to `.env` and rotate real values before `docker compose up`.
# Demo defaults below match `keycloak/realm-tbox.json`; keep in sync if you change one.

KEYCLOAK_CLIENT_SECRET=replace-with-output-of-openssl-rand-hex-32
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-strong-password
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=replace-with-strong-password
APISIX_SESSION_SECRET=replace-with-32-char-random-string
APISIX_PORT=9080
